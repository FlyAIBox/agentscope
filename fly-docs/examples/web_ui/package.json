{
	"name": "agentscope-web-ui",
	"version": "1.0.0",
	"private": true,
	"scripts": {
		"dev:frontend": "pnpm --filter frontend dev",
		"dev:backend": "pnpm --filter backend dev",
		"dev": "concurrently \"pnpm dev:frontend\" \"pnpm dev:backend\"",
		"build:frontend": "pnpm --filter frontend build",
		"build:backend": "pnpm --filter backend build",
		"build": "pnpm build:frontend && pnpm build:backend",
		"format": "prettier --write . && pnpm --filter frontend lint:fix",
		"format:check": "prettier --check . && pnpm --filter frontend lint",
		"prepare": "husky"
	},
	"lint-staged": {
		"frontend/**/*.{ts,tsx}": [
			"prettier --write",
			"cd frontend && pnpm eslint --fix"
		],
		"backend/**/*.{ts,js}": [
			"prettier --write"
		],
		"*.{json,css,md,html,yaml,yml}": [
			"prettier --write"
		]
	},
	"devDependencies": {
		"concurrently": "^8.2.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.5",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.5",
		"prettier": "^3.8.3"
	},
	"packageManager": "pnpm@11.12.0+sha512.820a6fbd0d9f04c226638002aead1e45340a9139dd5dc077c1d83ef44aa2481c8eb6637b4c9aa696a3c7e35ba818e49cf27213e5f2b91138d09b7a3e26e898ba"
}
